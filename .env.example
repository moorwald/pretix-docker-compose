# Pretix Configuration for Coolify
# Copy to .env and adjust values

# =============================================================================
# REQUIRED - Change these!
# =============================================================================

# Your pretix domain (without https://)
# Testing: pretix.moorwald.dev | Production: tickets.mautic.org
PRETIX_DOMAIN=pretix.moorwald.dev

# Database password (generate a secure one!)
POSTGRES_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# =============================================================================
# INSTANCE SETTINGS
# =============================================================================

PRETIX_INSTANCE_NAME=MautiCon Tickets
PRETIX_CURRENCY=EUR
PRETIX_LOCALE=en
PRETIX_TIMEZONE=Europe/London

# =============================================================================
# MAIL SETTINGS
# =============================================================================

MAIL_FROM=tickets@moorwald.dev
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
# Use "on" or "off" (not True/False)
MAIL_TLS=on
MAIL_SSL=off
